{
  "name": "jamissue",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "tsx scripts/build-frontend.ts",
    "lint": "eslint src scripts deploy/api-worker-shell test",
    "test": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs run",
    "test:unit": "tsx scripts/run-unit-tests.ts",
    "test:integration": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs run test/integration",
    "test:regression": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs run test/regression",
    "test:smoke:ui": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs run test/smoke",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:regression && npm run test:smoke:ui",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "smoke": "tsx scripts/run-public-smoke-checks.ts",
    "smoke:public": "tsx scripts/run-public-smoke-checks.ts",
    "smoke:protected": "tsx scripts/run-protected-smoke-checks.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
