# Cloudflare 공개 도메인 (브라우저가 접근 가능한 주소)
PUBLIC_APP_BASE_URL=https://jamissue.example.com
APP_FRONTEND_URL=https://jamissue.example.com
APP_CORS_ORIGINS=https://jamissue.example.com
HOST_HTTP_PORT=8080

# 프론트엔드 런타임 설정 (build-frontend.mjs가 window.__JAMISSUE_CONFIG__로 주입)
# 여기서 "PUBLIC_"로 시작하는 변수만 브라우저에 노출됨
PUBLIC_NAVER_MAP_CLIENT_ID=3k6vfi8mxs
# or
# NAVER_MAP_CLIENT_ID=YOUR_NAVER_MAP_CLIENT_ID

# 백엔드 전용 시크릿 (프론트에 노출 X)
# APP_SESSION_SECRET: 쿠키 서명 시크릿 (세션 토큰 발급)
# APP_JWT_SECRET: Access Token 디지털 서명용 시크릿
APP_SESSION_SECRET=
APP_JWT_SECRET=
APP_ADMIN_USER_IDS=

# Supabase Postgres (transaction 또는 session pooler URL)
APP_DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# 백엔드 런타임 설정
APP_WORKERS=2
# HTTPS 환경 (프로덕션): 쿠키 보안 플래그 활성화
APP_SESSION_HTTPS=true
# JWT Access Token 유효 기간 (분 단위, 20160분 = 14일)
APP_JWT_ACCESS_TOKEN_MINUTES=20160
APP_SEED_DEMO_DATA=false
APP_CLEANUP_LEGACY_DEMO_DATA=true
APP_AUTO_IMPORT_PUBLIC_DATA=true
APP_MAX_UPLOAD_SIZE_BYTES=5242880
# 스탬프 타올 수 있는 최대 거리 (미터, App.tsx의 STAMP_UNLOCK_RADIUS_METERS와 동기화)
APP_STAMP_UNLOCK_RADIUS_METERS=120

# 공개 데이터 / 이벤트 소스
APP_PUBLIC_DATA_SOURCE_URL=
APP_PUBLIC_EVENT_SOURCE_URL=
APP_PUBLIC_EVENT_SERVICE_KEY=
APP_PUBLIC_EVENT_CITY_KEYWORD=daejeon
APP_PUBLIC_EVENT_REFRESH_MINUTES=360

# OAuth callbacks should use the public domain
APP_NAVER_LOGIN_CLIENT_ID=
APP_NAVER_LOGIN_CLIENT_SECRET=
APP_NAVER_LOGIN_CALLBACK_URL=https://jamissue.example.com/api/auth/naver/callback
APP_GOOGLE_LOGIN_CLIENT_ID=
APP_GOOGLE_LOGIN_CLIENT_SECRET=
APP_GOOGLE_LOGIN_CALLBACK_URL=https://jamissue.example.com/api/auth/google/callback
APP_KAKAO_LOGIN_CLIENT_ID=
APP_KAKAO_LOGIN_CLIENT_SECRET=
APP_KAKAO_LOGIN_CALLBACK_URL=https://jamissue.example.com/api/auth/kakao/callback
APP_APPLE_LOGIN_CLIENT_ID=
APP_APPLE_LOGIN_CLIENT_SECRET=
APP_APPLE_LOGIN_CALLBACK_URL=https://jamissue.example.com/api/auth/apple/callback

# Optional pinned image tags from GHCR
FRONTEND_IMAGE=ghcr.io/OWNER/jamissue-frontend:deploy-latest
BACKEND_IMAGE=ghcr.io/OWNER/jamissue-backend:deploy-latest
